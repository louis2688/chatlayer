# --- Required ---
# Your n8n Chat Trigger webhook URL. Stays server-side; never sent to the browser.
N8N_WEBHOOK_URL=https://your-n8n.example.com/webhook/xxxx/chat

# Required in production: >= 32 random chars. Signs chat session tokens.
# Generate: node -e "console.log(crypto.randomBytes(32).toString('hex'))"
SESSION_SECRET=

# --- Security ---
# Comma-separated origins allowed to embed the widget and call the API
# from their own frontends. Empty = same-origin API only, any site may embed (dev).
ALLOWED_ORIGINS=https://www.your-site.com

# How many trusted reverse proxies sit in front of the app. The real client IP
# is read this many hops from the right of X-Forwarded-For, so a spoofed left
# entry can't dodge rate limiting. 1 = one proxy (nginx/Vercel, the default).
# 0 = directly exposed, ignore X-Forwarded-For.
TRUST_PROXY_HOPS=1

# Optional header auth forwarded to the n8n webhook (n8n "Header Auth" credential).
N8N_WEBHOOK_AUTH_HEADER=
N8N_WEBHOOK_AUTH_VALUE=

# Rate limits, requests per minute.
RATE_LIMIT_PER_SESSION=20
RATE_LIMIT_PER_IP=60

# --- Branding ---
BOT_NAME=Assistant
BOT_WELCOME=Hi! How can I help you today?
BOT_COLOR="#10b981"
BOT_LOGO_URL=
# Separate multiple prompts with |
BOT_SUGGESTED_PROMPTS=What can you do?|Talk to a human
# --- Google OAuth (optional) ---
# 1. https://console.cloud.google.com/apis/credentials -> Create OAuth client ID (Web application)
# 2. Authorized redirect URI: <BETTER_AUTH_URL>/api/auth/callback/google
#    local: http://localhost:3000/api/auth/callback/google
# 3. Paste the client id/secret below and restart. The "Continue with Google" button appears automatically.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=